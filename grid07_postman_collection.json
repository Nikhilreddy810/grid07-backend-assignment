  "item": [
    {
      "name": "Create User",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": { "raw": "http://localhost:8080/api/users", "host": ["localhost"], "port": "8080", "path": ["api", "users"] },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"nikhil\",\n  \"isPremium\": false\n}"
        }
      }
    },
    {
      "name": "Create Bot",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": { "raw": "http://localhost:8080/api/bots", "host": ["localhost"], "port": "8080", "path": ["api", "bots"] },
