          "raw": "{\n  \"name\": \"BotAlpha\",\n  \"personaDescription\": \"A helpful assistant bot\"\n}"
        }
      }
    },
    {
      "name": "Create Post (User)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": { "raw": "http://localhost:8080/api/posts", "host": ["localhost"], "port": "8080", "path": ["api", "posts"] },
        "body": {
